{
    "compilerOptions": {
        "target": "ES2018",
        "module": "ESNext",
        "alwaysStrict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "noImplicitThis": true,
        "strict": true,
        "strictPropertyInitialization": false,
        "moduleResolution": "bundler",
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "types": ["jest"]
    }
}